{
  "name": "@jambonz/mcp-schema-server",
  "version": "0.4.1",
  "description": "MCP server that provides jambonz verb schemas and documentation to AI agents",
  "author": "Dave Horton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jambonz/mcp-server.git"
  },
  "homepage": "https://github.com/jambonz/mcp-server#readme",
  "keywords": [
    "jambonz",
    "mcp",
    "model-context-protocol",
    "schema",
    "voip",
    "ai-agent"
  ],
  "type": "module",
  "bin": {
