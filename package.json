  },
  "peerDependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "eslint": "^9.3.0",
    "eslint-plugin-promise": "^6.2.0",
    "globals": "^15.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
